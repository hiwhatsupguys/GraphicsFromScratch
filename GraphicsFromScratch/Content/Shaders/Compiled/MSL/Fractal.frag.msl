#include <metal_stdlib>
#include <simd/simd.h>

using namespace metal;

struct main0_out
{
    float4 out_var_SV_Target0 [[color(0)]];
};

struct main0_in
{
    float2 in_var_TEXCOORD0 [[user(locn0)]];
};

fragment main0_out main0(main0_in in [[stage_in]])
{
    main0_out out = {};
    out.out_var_SV_Target0 = float4(precise::max(0.0, 1.0 - length((in.in_var_TEXCOORD0 * 2.0) - float2(1.0))), 0.0, 0.0, 1.0);
    return out;
}

